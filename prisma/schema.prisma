generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String       @id @default(cuid())
  studentId   String
  name        String
  grade       Int
  department  String
  gpa         Float?
  courses     UserCourse[]
  attendances Attendance[]
  reviews     Review[]
}

model Course {
  id          String       @id @default(cuid())
  code        String
  name        String
  teacher     String
  credits     Float
  category    String
  syllabus    String?
  dayOfWeek   Int
  period      Int
  userCourses UserCourse[]
  attendances Attendance[]
  reviews     Review[]
  grades      Grade[]
}

model UserCourse {
  id       String @id @default(cuid())
  userId   String
  courseId String
  semester String
  user     User   @relation(fields: [userId], references: [id])
  course   Course @relation(fields: [courseId], references: [id])
}

model Attendance {
  id       String @id @default(cuid())
  userId   String
  courseId String
  date     String
  status   String
  user     User   @relation(fields: [userId], references: [id])
  course   Course @relation(fields: [courseId], references: [id])
}

model Review {
  id        String   @id @default(cuid())
  courseId  String
  userId    String
  content   String
  rating    Int
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Grade {
  id       String @id @default(cuid())
  userId   String
  courseId String
  score    String
  credits  Float
  course   Course @relation(fields: [courseId], references: [id])
}

model News {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())
}